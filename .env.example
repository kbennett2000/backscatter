# backscatter container config — copy to `.env` and edit. All optional; sane defaults.
# These map straight to the app's Config (no code knows it's in Docker).

# Locations to seed the archive's store on FIRST run (empty DB). After that the DB is
# the source of truth — edit locations in the UI; this env is ignored once seeded.
# JSON list; exactly one "default": true. Default below = Home / KFTG (Denver area).
BACKSCATTER_LOCATIONS=[{"name":"Home","lat":39.3603,"lon":-104.5969,"default":true}]

# Retention (ADR-0009). Age limit in days (0 disables); size cap in GB (unset = off).
BACKSCATTER_RETENTION_DAYS=30
# BACKSCATTER_RETENTION_MAX_GB=50

# How often the collect loop polls S3 (seconds). 60 captures every volume sanely.
# BACKSCATTER_POLL_INTERVAL=60

# Pin a specific radar for the default location instead of nearest-by-lat/lon.
# BACKSCATTER_SITE=KFTG

# The port the web UI is served on (used both inside the container and published to your
# computer). Open the app at http://localhost:8085. Change this one line if 8085 is taken
# or you prefer another number.
BACKSCATTER_PORT=8085

# Run the container as your host user so the ./data bind mount is writable as non-root.
# Defaults to 1000:1000 (typical single-user Linux). If yours differs, set these to the
# output of `id -u` and `id -g`.
PUID=1000
PGID=1000
