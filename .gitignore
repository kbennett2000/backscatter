# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual env / tooling caches
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# backscatter data — never commit radar volumes, rendered tiles, or the index DB, but
# DO keep an empty data/ dir (via data/.gitkeep). A fresh clone then already has it owned
# by you; otherwise Docker creates the bind-mount source as root and the non-root
# container can't write the DB (see docs Help & FAQ).
/data/*
!/data/.gitkeep
tiles/
*.db
*.sqlite
*.sqlite3

# Docker — local env file (secrets/host-specific); .env.example is the tracked template
.env

# MkDocs build output (generated by `mkdocs build`; the docs source lives in docs/)
site/
